# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=videosite
DB_PASSWORD=
DB_NAME=videosite

# Redis (required — used for sessions, permission cache, watch & transcode
# progress coalescing, and rate limiting). Server should be configured with
# maxmemory-policy volatile-lru and appendonly yes for safe operation.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# R2
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=videos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_DOMAIN=video.yourdomain.com

# Session
SESSION_SECRET=

# App
NODE_ENV=development
PORT=3000

# Email (SMTP)
SMTP_HOST=smtp.server.com
SMTP_PORT=465
SMTP_USER=postmaster@yourdomain.com
SMTP_PASS=your-mailgun-smtp-password
SMTP_SECURE=true
SMTP_FROM_NAME="My App"
SMTP_FROM_ADDRESS=noreply@yourdomain.com
SMTP_REPLY_TO=support@yourdomain.com

# MFA
MFA_ENCRYPTION_KEY=your-32-byte-hex-key-here

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
