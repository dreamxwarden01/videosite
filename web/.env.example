# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=videosite
DB_PASSWORD=
DB_NAME=videosite

# Redis (required — used for sessions, permission cache, watch & transcode
# progress coalescing, and rate limiting). Server should be configured with
# maxmemory-policy volatile-lru and appendonly yes for safe operation.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Project-level key prefix. ioredis transparently prepends this to every
# key, so the same Redis instance can host other apps (SSO, email queue,
# etc.) without collisions. Defaults to "videosite:" if unset. Set to an
# empty string to disable.
# REDIS_KEY_PREFIX=videosite:

# R2
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=videos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_DOMAIN=video.yourdomain.com

# Session
SESSION_SECRET=

# App
NODE_ENV=development
PORT=3000

# Email is sent via the email-sender Cloudflare Worker — no SMTP config here.
# Configure it in the admin Settings page (Cloudflare → Email Sending) and
# `wrangler secret put EMAIL_HMAC_SECRET` on the email-sender Worker.

# MFA
MFA_ENCRYPTION_KEY=your-32-byte-hex-key-here

# At-rest encryption key for sensitive site_settings rows (HMAC playback
# secret, email-sender HMAC secret, CF Access service token secret).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required from migration 035 onward; server refuses to start without it.
SETTINGS_SECRET_ENCRYPTION_KEY=

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
